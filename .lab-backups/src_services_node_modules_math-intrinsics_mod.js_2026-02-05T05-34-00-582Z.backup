  "content": "'use strict';\n\nvar $floor = require('./floor');\n\n/** @type {import('./mod')} */\nmodule.exports = function mod(number, modulo) {\n\tvar remain = number % modulo;\n\treturn $floor(remain >= 0 ? remain : remain + modulo);\n};\n"
