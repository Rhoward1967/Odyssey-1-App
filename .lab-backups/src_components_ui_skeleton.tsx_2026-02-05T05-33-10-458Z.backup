  "content": "import * as React from \"react\"\r\nimport { cn } from \"@/lib/utils\"\r\n\r\ninterface SkeletonProps extends React.HTMLAttributes<HTMLDivElement> {\r\n  animated?: boolean\r\n}\r\n\r\nfunction Skeleton({\r\n  className,\r\n  animated = true,\r\n  ...props\r\n}: SkeletonProps) {\r\n  return (\r\n    <div\r\n      className={cn(\r\n        \"rounded-md bg-muted/70\",\r\n        animated && \"animate-pulse\",\r\n        className\r\n      )}\r\n      {...props}\r\n    />\r\n  )\r\n}\r\n\r\nexport { Skeleton }\r\n"
