  "originalPath": "src\\pages\\Checkout.tsx",
  "timestamp": "2026-02-05T05:33:13.784Z",
  "hash": "9f6d4f75c4a7a73beca536af4071cbfb1642f06995486761092d51d09d444bc7",
  "size": 2745,
  "content": "import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';\r\nimport { supabase } from '@/lib/supabaseClient';\r\nimport { Loader2 } from 'lucide-react';\r\nimport { useEffect, useState } from 'react';\r\nimport { useLocation, useNavigate } from 'react-router-dom';\r\n\r\nexport default function Checkout() {\r\n  const location = useLocation();\r\n  const navigate = useNavigate();\r\n  const [loading, setLoading] = useState(true);\r\n  const [processing, setProcessing] = useState(false);\r\n  \r\n  const tier = location.state?.tier;\r\n  const price = location.state?.price;\r\n  const industry = location.state?.industry;\r\n\r\n  useEffect(() => {\r\n    if (!tier || !price) {\r\n      navigate('/pricing');\r\n      return;\r\n    }\r\n    initializeStripe();\r\n  }, [tier, price, navigate]);\r\n\r\n  async function initializeStripe() {\r\n    try {\r\n      // Get current user\r\n      const { data: { user } } = await supabase.auth.getUser();\r\n      if (!user) {\r\n        navigate('/login');\r\n        return;\r\n      }\r\n\r\n      // Create Stripe checkout session via Edge Function\r\n      const { data, error } = await supabase.functions.invoke('create-checkout-session', {\r\n        body: {\r\n          tier,\r\n          price,\r\n          industry,\r\n          userId: user.id,\r\n          successUrl: `${window.location.origin}/dashboard?session_id={CHECKOUT_SESSION_ID}`,\r\n          cancelUrl: `${window.location.origin}/pricing`\r\n        }\r\n      });\r\n\r\n      if (error) throw error;\r\n\r\n      if (data?.url) {\r\n        // Redirect to Stripe Checkout\r\n        window.location.href = data.url;\r\n      }\r\n    } catch (error) {\r\n      console.error('Checkout error:', error);\r\n      alert('Error initializing checkout. Please try again.');\r\n      navigate('/pricing');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-gradient-to-b from-background to-muted/20 flex items-center justify-center p-4\">\r\n      <Card className=\"max-w-md w-full\">\r\n        <CardHeader className=\"text-center\">\r\n          <CardTitle>Redirecting to Checkout</CardTitle>\r\n          <CardDescription>\r\n            Please wait while we prepare your payment...\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"flex flex-col items-center gap-4\">\r\n          <Loader2 className=\"h-8 w-8 animate-spin text-primary\" />\r\n          <div className=\"text-center\">\r\n            <p className=\"font-semibold\">{tier} Plan</p>\r\n            <p className=\"text-2xl font-bold text-primary\">{price}/month</p>\r\n            <p className=\"text-sm text-muted-foreground mt-2\">\r\n              Industry: {industry}\r\n            </p>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n"
}