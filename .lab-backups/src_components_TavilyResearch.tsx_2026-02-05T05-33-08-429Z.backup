  "originalPath": "src\\components\\TavilyResearch.tsx",
  "timestamp": "2026-02-05T05:33:08.429Z",
  "hash": "b30e88e03c717c3e6dc16a4655324f1de526cbcc84723045aa4b5c6018cc97d5",
  "size": 7216,
  "content": "import React, { useState } from 'react';\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Badge } from '@/components/ui/badge';\r\nimport { Search, ExternalLink, Clock, CheckCircle, AlertCircle, Loader2 } from 'lucide-react';\r\nimport { supabase } from '@/lib/supabaseClient';\r\n\r\ninterface SearchResult {\r\n  title: string;\r\n  url: string;\r\n  content: string;\r\n  score: number;\r\n}\r\n\r\ninterface ResearchResponse {\r\n  success: boolean;\r\n  answer?: string;\r\n  results?: SearchResult[];\r\n  query?: string;\r\n  timestamp?: string;\r\n  error?: string;\r\n}\r\n\r\nconst TavilyResearch: React.FC = () => {\r\n  const [query, setQuery] = useState('');\r\n  const [loading, setLoading] = useState(false);\r\n  const [results, setResults] = useState<ResearchResponse | null>(null);\r\n  const [searchDepth, setSearchDepth] = useState<'basic' | 'advanced'>('basic');\r\n\r\n  const handleSearch = async () => {\r\n    if (!query.trim()) return;\r\n    \r\n    setLoading(true);\r\n    try {\r\n      const { data, error } = await supabase.functions.invoke('tavily-research', {\r\n        body: {\r\n          query: query.trim(),\r\n          searchDepth,\r\n          includeImages: false,\r\n          maxResults: 5\r\n        }\r\n      });\r\n\r\n      if (error) throw error;\r\n      setResults(data);\r\n    } catch (error) {\r\n      setResults({\r\n        success: false,\r\n        error: error instanceof Error ? error.message : 'Search failed',\r\n        query\r\n      });\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const handleKeyPress = (e: React.KeyboardEvent) => {\r\n    if (e.key === 'Enter') {\r\n      handleSearch();\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-gradient-to-br from-purple-50 via-blue-50 to-indigo-100 p-6\">\r\n      <div className=\"max-w-4xl mx-auto\">\r\n        <div className=\"text-center mb-8\">\r\n          <h1 className=\"text-4xl font-bold text-gray-900 mb-4\">\r\n            AI Research Assistant\r\n          </h1>\r\n          <p className=\"text-xl text-gray-600\">\r\n            Powered by Tavily's advanced search intelligence\r\n          </p>\r\n        </div>\r\n\r\n        {/* Search Interface */}\r\n        <Card className=\"mb-8\">\r\n          <CardHeader>\r\n            <CardTitle className=\"flex items-center gap-2\">\r\n              <Search className=\"w-5 h-5\" />\r\n              Research Query\r\n            </CardTitle>\r\n          </CardHeader>\r\n          <CardContent className=\"space-y-4\">\r\n            <div className=\"flex gap-2\">\r\n              <Input\r\n                placeholder=\"Enter your research question...\"\r\n                value={query}\r\n                onChange={(e) => setQuery(e.target.value)}\r\n                onKeyPress={handleKeyPress}\r\n                className=\"flex-1\"\r\n              />\r\n              <Button \r\n                onClick={handleSearch} \r\n                disabled={loading || !query.trim()}\r\n                className=\"bg-purple-600 hover:bg-purple-700\"\r\n              >\r\n                {loading ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Search className=\"w-4 h-4\" />}\r\n              </Button>\r\n            </div>\r\n            \r\n            <div className=\"flex gap-2\">\r\n              <Button\r\n                variant={searchDepth === 'basic' ? 'default' : 'outline'}\r\n                size=\"sm\"\r\n                onClick={() => setSearchDepth('basic')}\r\n              >\r\n                Basic Search\r\n              </Button>\r\n              <Button\r\n                variant={searchDepth === 'advanced' ? 'default' : 'outline'}\r\n                size=\"sm\"\r\n                onClick={() => setSearchDepth('advanced')}\r\n              >\r\n                Advanced Search\r\n              </Button>\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        {/* Results */}\r\n        {results && (\r\n          <div className=\"space-y-6\">\r\n            {results.success ? (\r\n              <>\r\n                {/* AI Answer */}\r\n                {results.answer && (\r\n                  <Card className=\"border-green-200 bg-green-50\">\r\n                    <CardHeader>\r\n                      <CardTitle className=\"flex items-center gap-2 text-green-800\">\r\n                        <CheckCircle className=\"w-5 h-5\" />\r\n                        AI Summary\r\n                      </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent>\r\n                      <p className=\"text-green-900 leading-relaxed\">{results.answer}</p>\r\n                      {results.timestamp && (\r\n                        <div className=\"flex items-center gap-2 mt-4 text-sm text-green-600\">\r\n                          <Clock className=\"w-4 h-4\" />\r\n                          {new Date(results.timestamp).toLocaleString()}\r\n                        </div>\r\n                      )}\r\n                    </CardContent>\r\n                  </Card>\r\n                )}\r\n\r\n                {/* Search Results */}\r\n                {results.results && results.results.length > 0 && (\r\n                  <div className=\"space-y-4\">\r\n                    <h3 className=\"text-2xl font-semibold text-gray-900\">Source Results</h3>\r\n                    {results.results.map((result, index) => (\r\n                      <Card key={index} className=\"hover:shadow-lg transition-shadow\">\r\n                        <CardContent className=\"pt-6\">\r\n                          <div className=\"flex justify-between items-start mb-3\">\r\n                            <h4 className=\"text-lg font-semibold text-gray-900 flex-1\">\r\n                              {result.title}\r\n                            </h4>\r\n                            <Badge variant=\"secondary\" className=\"ml-2\">\r\n                              Score: {(result.score * 100).toFixed(0)}%\r\n                            </Badge>\r\n                          </div>\r\n                          <p className=\"text-gray-600 mb-4 leading-relaxed\">\r\n                            {result.content}\r\n                          </p>\r\n                          <Button\r\n                            variant=\"outline\"\r\n                            size=\"sm\"\r\n                            onClick={() => window.open(result.url, '_blank')}\r\n                            className=\"flex items-center gap-2\"\r\n                          >\r\n                            <ExternalLink className=\"w-4 h-4\" />\r\n                            View Source\r\n                          </Button>\r\n                        </CardContent>\r\n                      </Card>\r\n                    ))}\r\n                  </div>\r\n                )}\r\n              </>\r\n            ) : (\r\n              <Card className=\"border-red-200 bg-red-50\">\r\n                <CardContent className=\"pt-6\">\r\n                  <div className=\"flex items-center gap-2 text-red-800 mb-2\">\r\n                    <AlertCircle className=\"w-5 h-5\" />\r\n                    <span className=\"font-semibold\">Search Error</span>\r\n                  </div>\r\n                  <p className=\"text-red-700\">{results.error}</p>\r\n                </CardContent>\r\n              </Card>\r\n            )}\r\n          </div>\r\n        )}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default TavilyResearch;"
}