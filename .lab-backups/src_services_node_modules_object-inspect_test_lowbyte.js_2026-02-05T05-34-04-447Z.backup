  "content": "var test = require('tape');\nvar inspect = require('../');\n\nvar obj = { x: 'a\\r\\nb', y: '\\x05! \\x1f \\x12' };\n\ntest('interpolate low bytes', function (t) {\n    t.plan(1);\n    t.equal(\n        inspect(obj),\n        \"{ x: 'a\\\\r\\\\nb', y: '\\\\x05! \\\\x1F \\\\x12' }\"\n    );\n});\n"
