  "content": "{\r\n  \"name\": \"@odyssey-1-ai/odyssey-platform\",\r\n  \"version\": \"2.0.0\",\r\n  \"private\": true,\r\n  \"type\": \"module\",\r\n  \"description\": \"ODYSSEY-1 AI Platform - Constitutional AI Governance & Neural Computing System\",\r\n  \"author\": \"ODYSSEY-1 AI LLC <rhoward@hjsservices.us>\",\r\n  \"license\": \"PROPRIETARY\",\r\n  \"copyright\": \"Copyright © 2025 ODYSSEY-1 AI LLC. All Rights Reserved.\",\r\n  \"repository\": {\r\n    \"type\": \"git\",\r\n    \"url\": \"https://github.com/Rhoward1967/Odyssey-1-App.git\"\r\n  },\r\n  \"keywords\": [\r\n    \"artificial-intelligence\",\r\n    \"constitutional-ai\",\r\n    \"neural-computing\",\r\n    \"governance-system\",\r\n    \"odyssey\",\r\n    \"patent-pending\"\r\n  ],\r\n  \"scripts\": {\r\n    \"dev\": \"vite\",\r\n    \"build\": \"vite build && npm run build:optimize\",\r\n    \"build:optimize\": \"echo Build optimized for production\",\r\n    \"build:dev\": \"vite build --mode development\",\r\n    \"test\": \"vitest run\",\r\n    \"test:watch\": \"vitest\",\r\n    \"test:ui\": \"vitest --ui\",\r\n    \"test:coverage\": \"vitest run --coverage\",\r\n    \"test:coverage:ui\": \"vitest --ui --coverage\",\r\n    \"test:services\": \"vitest run src/test/services\",\r\n    \"test:components\": \"vitest run src/test/components\",\r\n    \"test:e2e\": \"playwright test\",\r\n    \"test:e2e:ui\": \"playwright test --ui\",\r\n    \"test:e2e:debug\": \"playwright test --debug\",\r\n    \"test:e2e:report\": \"playwright show-report\",\r\n    \"lint\": \"eslint .\",\r\n    \"preview\": \"vite preview\",\r\n    \"bot\": \"npx dotenv -e .env -- tsx src/start-bot.ts\",\r\n    \"dev:all\": \"concurrently --kill-others \\\"npm run dev\\\" \\\"npm run bot\\\"\",\r\n    \"dev:separate\": \"echo Run 'npm run dev' in one terminal and 'npm run bot' in another\",\r\n    \"audit:system\": \"tsx src/services/roman-auto-audit.ts\",\r\n    \"audit:roman\": \"tsx src/services/roman-auto-audit.ts\",\r\n    \"auto:config-backup\": \"node scripts/auto_config_backup.js\"\r\n  },\r\n  \"dependencies\": {\r\n    \"@anthropic-ai/sdk\": \"^0.68.0\",\r\n    \"@google/generative-ai\": \"^0.24.1\",\r\n    \"@hookform/resolvers\": \"^3.9.0\",\r\n    \"@radix-ui/react-accordion\": \"^1.2.0\",\r\n    \"@radix-ui/react-alert-dialog\": \"^1.1.1\",\r\n    \"@radix-ui/react-aspect-ratio\": \"^1.1.0\",\r\n    \"@radix-ui/react-avatar\": \"^1.1.0\",\r\n    \"@radix-ui/react-checkbox\": \"^1.3.3\",\r\n    \"@radix-ui/react-collapsible\": \"^1.1.0\",\r\n    \"@radix-ui/react-context-menu\": \"^2.2.1\",\r\n    \"@radix-ui/react-dialog\": \"^1.1.15\",\r\n    \"@radix-ui/react-dropdown-menu\": \"^2.1.1\",\r\n    \"@radix-ui/react-hover-card\": \"^1.1.1\",\r\n    \"@radix-ui/react-label\": \"^2.1.0\",\r\n    \"@radix-ui/react-menubar\": \"^1.1.1\",\r\n    \"@radix-ui/react-navigation-menu\": \"^1.2.0\",\r\n    \"@radix-ui/react-popover\": \"^1.1.1\",\r\n    \"@radix-ui/react-progress\": \"^1.1.0\",\r\n    \"@radix-ui/react-radio-group\": \"^1.2.0\",\r\n    \"@radix-ui/react-scroll-area\": \"^1.1.0\",\r\n    \"@radix-ui/react-select\": \"^2.2.6\",\r\n    \"@radix-ui/react-separator\": \"^1.1.0\",\r\n    \"@radix-ui/react-slider\": \"^1.2.0\",\r\n    \"@radix-ui/react-slot\": \"^1.1.0\",\r\n    \"@radix-ui/react-switch\": \"^1.1.0\",\r\n    \"@radix-ui/react-tabs\": \"^1.1.0\",\r\n    \"@radix-ui/react-toast\": \"^1.2.1\",\r\n    \"@radix-ui/react-toggle\": \"^1.1.0\",\r\n    \"@radix-ui/react-toggle-group\": \"^1.1.0\",\r\n    \"@radix-ui/react-tooltip\": \"^1.1.4\",\r\n    \"@sendgrid/mail\": \"^8.1.6\",\r\n    \"@stripe/react-stripe-js\": \"^5.4.1\",\r\n    \"@stripe/stripe-js\": \"^8.6.0\",\r\n    \"@supabase/supabase-js\": \"^2.86.2\",\r\n    \"@tanstack/react-query\": \"^5.56.2\",\r\n    \"@types/uuid\": \"^10.0.0\",\r\n    \"@types/web3\": \"^1.2.2\",\r\n    \"@vercel/analytics\": \"^1.5.0\",\r\n    \"@vercel/speed-insights\": \"^1.2.0\",\r\n    \"class-variance-authority\": \"^0.7.1\",\r\n    \"clsx\": \"^2.1.1\",\r\n    \"cmdk\": \"^1.0.0\",\r\n    \"coingecko-api\": \"^1.0.10\",\r\n    \"date-fns\": \"^3.6.0\",\r\n    \"discord.js\": \"^14.24.2\",\r\n    \"dotenv\": \"^17.2.3\",\r\n    \"embla-carousel-react\": \"^8.3.0\",\r\n    \"ethers\": \"^6.15.0\",\r\n    \"highlight.js\": \"^11.9.0\",\r\n    \"input-otp\": \"^1.2.4\",\r\n    \"lucide-react\": \"^0.462.0\",\r\n    \"marked\": \"^12.0.1\",\r\n    \"next-themes\": \"^0.3.0\",\r\n    \"node-cron\": \"^4.2.1\",\r\n    \"openai\": \"^6.7.0\",\r\n    \"papaparse\": \"^5.5.3\",\r\n    \"react\": \"^18.3.1\",\r\n    \"react-day-picker\": \"^8.10.1\",\r\n    \"react-dom\": \"^18.3.1\",\r\n    \"react-hook-form\": \"^7.53.0\",\r\n    \"react-resizable-panels\": \"^2.1.3\",\r\n    \"react-router-dom\": \"^6.26.2\",\r\n    \"recharts\": \"^2.12.7\",\r\n    \"sonner\": \"^1.5.0\",\r\n    \"stripe\": \"^20.3.0\",\r\n    \"tailwind-merge\": \"^2.5.2\",\r\n    \"tailwindcss-animate\": \"^1.0.7\",\r\n    \"three\": \"^0.180.0\",\r\n    \"uuid\": \"^11.1.0\",\r\n    \"vaul\": \"^0.9.3\",\r\n    \"web3\": \"^4.16.0\",\r\n    \"xlsx\": \"^0.18.5\",\r\n    \"zod\": \"^3.23.8\"\r\n  },\r\n  \"devDependencies\": {\r\n    \"@eslint/js\": \"^9.9.0\",\r\n    \"@playwright/test\": \"^1.57.0\",\r\n    \"@tailwindcss/typography\": \"^0.5.16\",\r\n    \"@testing-library/jest-dom\": \"^6.1.4\",\r\n    \"@testing-library/react\": \"^14.1.2\",\r\n    \"@testing-library/user-event\": \"^14.5.1\",\r\n    \"@types/jest\": \"^30.0.0\",\r\n    \"@types/node\": \"^22.5.5\",\r\n    \"@types/react\": \"^18.3.3\",\r\n    \"@types/react-dom\": \"^18.3.0\",\r\n    \"@vitejs/plugin-react-swc\": \"^3.5.0\",\r\n    \"@vitest/ui\": \"^3.2.4\",\r\n    \"autoprefixer\": \"^10.4.20\",\r\n    \"babel-jest\": \"^29.7.0\",\r\n    \"bundlesize\": \"^0.18.1\",\r\n    \"concurrently\": \"^8.2.2\",\r\n    \"eslint\": \"^9.9.0\",\r\n    \"eslint-plugin-react-hooks\": \"^5.1.0-rc.0\",\r\n    \"eslint-plugin-react-refresh\": \"^0.4.9\",\r\n    \"globals\": \"^15.9.0\",\r\n    \"identity-obj-proxy\": \"^3.0.0\",\r\n    \"jsdom\": \"^27.0.0\",\r\n    \"postcss\": \"^8.4.47\",\r\n    \"prettier\": \"^3.1.0\",\r\n    \"supabase\": \"^2.50.14\",\r\n    \"tailwindcss\": \"^3.4.11\",\r\n    \"tsx\": \"^4.20.6\",\r\n    \"typescript\": \"^5.5.3\",\r\n    \"typescript-eslint\": \"^8.0.1\",\r\n    \"vite\": \"^7.1.9\",\r\n    \"vitest\": \"^3.2.4\"\r\n  }\r\n}\r\n"
