  "content": "'use strict';\n\nvar $isNaN = require('./isNaN');\n\n/** @type {import('./isFinite')} */\nmodule.exports = function isFinite(x) {\n\treturn (typeof x === 'number' || typeof x === 'bigint')\n        && !$isNaN(x)\n        && x !== Infinity\n        && x !== -Infinity;\n};\n\n"
