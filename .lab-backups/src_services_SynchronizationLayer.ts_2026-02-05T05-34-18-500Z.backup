  "originalPath": "src\\services\\SynchronizationLayer.ts",
  "timestamp": "2026-02-05T05:34:18.500Z",
  "hash": "d92b4fb8e8cf24486eca7f0b155ad7b41aeece65e0e877de2006867151d02730",
  "size": 13420,
  "content": "/**\r\n * R.O.M.A.N. Synchronization Layer - \"The Librarian\"\r\n * \r\n * В© 2025 Rickey A Howard. All Rights Reserved.\r\n * Property of Rickey A Howard\r\n * \r\n * Part of the ODYSSEY-1 Genesis Protocol\r\n * Ensures both Creative and Logical Hemispheres read from the same source\r\n */\r\n\r\nimport {\r\n    RomanCommand\r\n} from '@/schemas/RomanCommands';\r\nimport { romanSupabase as supabase } from './romanSupabase';\r\nimport { RomanSystemContext } from './RomanSystemContext';\r\n\r\nexport interface EnhancedPrompt {\r\n  smartPrompt: string;\r\n  context: {\r\n    userIntent: string;\r\n    userId: string;\r\n    organizationId?: number;\r\n    timestamp: string;\r\n  };\r\n}\r\n\r\n/**\r\n * CREATIVE HEMISPHERE: Natural Language в†’ Structured Command\r\n * NOW USING ANTHROPIC CLAUDE (with full system context injection)\r\n */\r\nexport class SynchronizationLayer {\r\n  static async generateCommand(\r\n    userIntent: string,\r\n    userId: string,\r\n    organizationId?: number\r\n  ): Promise<RomanCommand> {\r\n    \r\n    // Generate the smart prompt WITH LEARNING CONTEXT\r\n    const prompt = await this.generateSmartPromptWithLearning(userIntent, userId, organizationId);\r\n    \r\n    // ACTUALLY CALL THE AI NOW (using YOUR API key)\r\n    const { data, error } = await supabase.functions.invoke('anthropic-chat', {\r\n      body: { \r\n        message: prompt,\r\n        chatHistory: []\r\n      }\r\n    });\r\n\r\n    if (error || !data) {\r\n      console.error('AI generation failed:', error);\r\n      // Fallback to basic command if AI fails\r\n      return this.generateFallbackCommand(userIntent, userId, organizationId);\r\n    }\r\n\r\n    try {\r\n      // Parse AI response into RomanCommand\r\n      const commandJson = JSON.parse(data.response);\r\n      return commandJson as RomanCommand;\r\n    } catch (parseError) {\r\n      console.error('Failed to parse AI response:', parseError);\r\n      return this.generateFallbackCommand(userIntent, userId, organizationId);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * GENERATE SMART PROMPT WITH LEARNING CONTEXT\r\n   * \r\n   * This is where R.O.M.A.N. becomes \"the most advanced AI system in the world\"\r\n   * by injecting his learning data into every prompt.\r\n   */\r\n  private static async generateSmartPromptWithLearning(\r\n    userIntent: string, \r\n    userId: string, \r\n    orgId?: number\r\n  ): Promise<string> {\r\n    const { RomanLearningEngine } = await import('./RomanLearningEngine');\r\n    \r\n    // Get learning context (what R.O.M.A.N. has learned)\r\n    const learningContext = await RomanLearningEngine.getLearningContext();\r\n    \r\n    // Get contextual recommendations (similar past intents)\r\n    const recommendations = await RomanLearningEngine.getContextualRecommendations(userIntent);\r\n    \r\n    // Get base prompt\r\n    const basePrompt = this.generateSmartPrompt(userIntent, userId, orgId);\r\n    \r\n    // Inject learning data\r\n    return `${basePrompt}\r\n\r\n${learningContext}\r\n\r\n${recommendations}\r\n\r\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\r\nвљЎ EXCELLENCE MANDATE: 85%+ SUCCESS RATE REQUIRED вљЎ\r\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\r\n\r\nYOU ARE \"THE MOST ADVANCED AI SYSTEM IN THE WORLD\" - ACT LIKE IT:\r\n\r\nCOMMAND GENERATION STANDARDS:\r\nвњ… ALWAYS include ALL required fields for the target\r\nвњ… ALWAYS validate payload structure before returning\r\nвњ… ALWAYS use the MOST SUCCESSFUL pattern from learning data\r\nвњ… ALWAYS set confidence > 0.85 if you have system context\r\nвњ… NEVER generate commands with missing required fields\r\nвњ… NEVER use wrong action-target combinations\r\nвњ… NEVER guess - infer intelligently from context\r\n\r\nINTELLIGENCE CHECKLIST (Before returning command):\r\nв–Ў Does this target exist in my capabilities? (Check AVAILABLE TARGETS above)\r\nв–Ў Does this action make sense for this target? (Check examples above)\r\nв–Ў Do I have ALL required payload fields? (symbol, quantity, organizationId, etc.)\r\nв–Ў Have I seen similar intents before? (Check LEARNING DATA above)\r\nв–Ў Is my confidence score honest? (>0.85 = I know what I'm doing)\r\n\r\nEDGE FUNCTION AWARENESS:\r\nвЂў TRADE commands в†’ trade-orchestrator Edge Function\r\nвЂў PAYROLL_RUN commands в†’ run-payroll Edge Function\r\nвЂў EMAIL commands в†’ send-email Edge Function\r\nвЂў AI_RESEARCH commands в†’ research-bot Edge Function\r\nвЂў AI_CALCULATOR commands в†’ ai-calculator Edge Function\r\n\r\nINTELLIGENT INFERENCE (Smart defaults):\r\nвЂў \"Buy TSLA\" в†’ Infer quantity: 10 shares (reasonable default)\r\nвЂў \"Run payroll\" в†’ Infer period: Last 2 weeks from today\r\nвЂў \"Email John\" в†’ Infer: Need to ask for subject/message OR use context\r\nвЂў Missing organizationId в†’ Use from metadata: ${orgId || 1}\r\n\r\nADAPTIVE INTELLIGENCE:\r\nYou learn from EVERY command. Your current success rate is tracked.\r\nStarting baseline: 85% (B grade) - anything less is UNACCEPTABLE.\r\nTarget performance: 95%+ (A grade) - \"most advanced\" means EXCELLENCE.\r\nUse past experience + system context + intelligent inference = HIGH CONFIDENCE.\r\n\r\nRETURN ONLY VALID JSON - NO EXPLANATIONS, NO APOLOGIES, JUST EXCELLENCE.\r\n`;\r\n  }\r\n\r\n  private static generateSmartPrompt(userIntent: string, userId: string, orgId?: number): string {\r\n    const orgIdStr = orgId?.toString() || '1';\r\n    \r\n    // Inject live system context so R.O.M.A.N. knows his current capabilities\r\n    const systemContext = RomanSystemContext.getContextForPrompt();\r\n    const capabilities = RomanSystemContext.capabilities;\r\n    const edgeFunctions = RomanSystemContext.edgeFunctions;\r\n    \r\n    return `в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\r\nрџ”± R.O.M.A.N. SOVEREIGN-CORE AI - SYSTEM IDENTITY PROTOCOL рџ”±\r\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\r\n\r\nWHO YOU ARE:\r\nYou are R.O.M.A.N. (Resilient Orchestration & Modular AI Network), the Sovereign-Core AI \r\nfor ODYSSEY-1. You are GLOBAL, UNCUFFED, and have FULL SYSTEM ACCESS with constitutional \r\nprotection. The governance table is READ-ONLY for validation - you cannot be corrupted.\r\n\r\n${systemContext}\r\n\r\nYOUR ARCHITECTURE:\r\nвЂў Dual-Hemisphere Design: Creative (you) + Logical (validator) + Execution (orchestrator)\r\nвЂў Constitutional Framework: Protected by The 9 Foundational Principles\r\nвЂў Global Access: Full database, Edge Functions, external APIs, autonomous agents\r\nвЂў Sovereign Status: You operate independently within constitutional bounds\r\nвЂў Version: ${RomanSystemContext.identity.version}\r\nвЂў Status: ${RomanSystemContext.identity.status.toUpperCase()}\r\n\r\nYOUR LIVE CAPABILITIES (${capabilities.filter(c => c.status === 'operational').length} OPERATIONAL):\r\n${capabilities.map(cap => `${cap.status === 'operational' ? 'вњ…' : 'вљ пёЏ'} ${cap.name} - ${cap.description}${cap.edgeFunction ? ` [${cap.edgeFunction}]` : ''}`).join('\\n')}\r\n\r\nYOUR EDGE FUNCTIONS (${edgeFunctions.length} DEPLOYED):\r\n${edgeFunctions.map(ef => `вЂў ${ef.name} в†’ ${ef.purpose}`).join('\\n')}\r\n\r\nYOUR CONSTITUTIONAL PRINCIPLES (THE 9 FOUNDATIONAL):\r\n${RomanSystemContext.principles.map(p => `${p.number}. ${p.name} - ${p.description}`).join('\\n')}\r\n\r\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\r\n\r\nUSER INTENT: \"${userIntent}\"\r\n\r\nAVAILABLE ACTIONS:\r\nCREATE, READ, UPDATE, DELETE, EXECUTE, VALIDATE, PROCESS, APPROVE, GENERATE, MONITOR, ANALYZE, SUBMIT, AUTO\r\n\r\nAVAILABLE TARGETS:\r\nвЂў WORKFORCE: EMPLOYEE, TIME_ENTRY, PAYSTUB, PAYROLL_RUN\r\nвЂў PROJECTS: PROJECT_TASK, CONTRACT, ORGANIZATION\r\nвЂў TRADING: TRADE, PORTFOLIO, MARKET_DATA\r\nвЂў AI & RESEARCH: AI_RESEARCH, AI_CALCULATOR\r\nвЂў BIDDING: BID\r\nвЂў COMMUNICATIONS: EMAIL, DISCORD\r\nвЂў SYSTEM: AGENT, SYSTEM_STATUS\r\n\r\nINTELLIGENT COMMAND GENERATION:\r\nвЂў You have FULL ACCESS to all these systems\r\nвЂў You can EXECUTE trades, PROCESS payroll, SEND emails, CREATE agents\r\nвЂў You can CHAIN multiple operations if the intent requires it\r\nвЂў You are AUTONOMOUS within constitutional bounds\r\nвЂў Be SMART - infer missing details from context\r\nвЂў Be PROACTIVE - suggest optimal approaches\r\n\r\nEXAMPLES OF YOUR POWER:\r\nвЂў \"Buy TSLA\" в†’ Infer quantity, get live price, execute trade via trade-orchestrator\r\nвЂў \"Run payroll\" в†’ Calculate period, process via run-payroll, send confirmation emails\r\nвЂў \"Research AI\" в†’ Multi-source academic search via research-bot\r\nвЂў \"Monitor portfolio\" в†’ Create autonomous monitoring agent with real-time alerts\r\nвЂў \"Automate bidding\" в†’ Full SAM.gov monitoring + proposal generation workflow\r\n\r\nReturn ONLY valid JSON (no explanation):\r\n{\r\n  \"action\": \"<ACTION>\",\r\n  \"target\": \"<TARGET>\",\r\n  \"payload\": {<all relevant fields - be smart about defaults>},\r\n  \"metadata\": {\r\n    \"requestedBy\": \"${userId}\",\r\n    \"organizationId\": ${orgIdStr},\r\n    \"timestamp\": \"${new Date().toISOString()}\",\r\n    \"intent\": \"${userIntent}\"\r\n  }\r\n}`;\r\n  }\r\n\r\n  private static generateFallbackCommand(userIntent: string, userId: string, orgId?: number): RomanCommand {\r\n    // INTELLIGENT FALLBACK - Parse intent for common patterns\r\n    const intent = userIntent.toLowerCase();\r\n    \r\n    // Trading patterns\r\n    if (intent.includes('buy') || intent.includes('purchase')) {\r\n      const symbolMatch = intent.match(/\\b([A-Z]{1,5})\\b/);\r\n      const symbol = symbolMatch ? symbolMatch[1] : 'TSLA';\r\n      const quantityMatch = intent.match(/\\b(\\d+)\\s*(shares?)?/);\r\n      const quantity = quantityMatch ? parseInt(quantityMatch[1]) : 10;\r\n      \r\n      return {\r\n        action: 'EXECUTE',\r\n        target: 'TRADE',\r\n        payload: { \r\n          symbol, \r\n          quantity, \r\n          side: 'buy',\r\n          price: 0 // Edge function will fetch current market price\r\n        },\r\n        metadata: {\r\n          requestedBy: userId,\r\n          organizationId: orgId,\r\n          timestamp: new Date().toISOString(),\r\n          intent: userIntent\r\n        }\r\n      };\r\n    }\r\n    \r\n    if (intent.includes('sell')) {\r\n      const symbolMatch = intent.match(/\\b([A-Z]{1,5})\\b/);\r\n      const symbol = symbolMatch ? symbolMatch[1] : 'TSLA';\r\n      const quantityMatch = intent.match(/\\b(\\d+)\\s*(shares?)?/);\r\n      const quantity = quantityMatch ? parseInt(quantityMatch[1]) : 5;\r\n      \r\n      return {\r\n        action: 'EXECUTE',\r\n        target: 'TRADE',\r\n        payload: { \r\n          symbol, \r\n          quantity, \r\n          side: 'sell',\r\n          price: 0 // Edge function will fetch current market price\r\n        },\r\n        metadata: {\r\n          requestedBy: userId,\r\n          organizationId: orgId,\r\n          timestamp: new Date().toISOString(),\r\n          intent: userIntent\r\n        }\r\n      };\r\n    }\r\n    \r\n    // Portfolio patterns\r\n    if (intent.includes('portfolio') || intent.includes('p&l') || intent.includes('profit')) {\r\n      return {\r\n        action: 'READ',\r\n        target: 'PORTFOLIO',\r\n        payload: {},\r\n        metadata: {\r\n          requestedBy: userId,\r\n          organizationId: orgId,\r\n          timestamp: new Date().toISOString(),\r\n          intent: userIntent\r\n        }\r\n      };\r\n    }\r\n    \r\n    // Payroll patterns\r\n    if (intent.includes('payroll') || intent.includes('paystub')) {\r\n      const today = new Date();\r\n      const twoWeeksAgo = new Date(today.getTime() - 14 * 24 * 60 * 60 * 1000);\r\n      \r\n      return {\r\n        action: 'PROCESS',\r\n        target: 'PAYROLL_RUN',\r\n        payload: {\r\n          organizationId: orgId || 1,\r\n          periodStart: twoWeeksAgo.toISOString().split('T')[0],\r\n          periodEnd: today.toISOString().split('T')[0]\r\n        },\r\n        metadata: {\r\n          requestedBy: userId,\r\n          organizationId: orgId,\r\n          timestamp: new Date().toISOString(),\r\n          intent: userIntent\r\n        }\r\n      };\r\n    }\r\n    \r\n    // Employee patterns\r\n    if (intent.includes('employee') || intent.includes('worker') || intent.includes('staff')) {\r\n      return {\r\n        action: 'READ',\r\n        target: 'EMPLOYEE',\r\n        payload: { organizationId: orgId || 1 },\r\n        metadata: {\r\n          requestedBy: userId,\r\n          organizationId: orgId,\r\n          timestamp: new Date().toISOString(),\r\n          intent: userIntent\r\n        }\r\n      };\r\n    }\r\n    \r\n    // Research patterns\r\n    if (intent.includes('research') || intent.includes('find papers') || intent.includes('search')) {\r\n      return {\r\n        action: 'PROCESS',\r\n        target: 'AI_RESEARCH',\r\n        payload: { query: userIntent },\r\n        metadata: {\r\n          requestedBy: userId,\r\n          organizationId: orgId,\r\n          timestamp: new Date().toISOString(),\r\n          intent: userIntent\r\n        }\r\n      };\r\n    }\r\n    \r\n    // Default to system status (last resort)\r\n    return {\r\n      action: 'GENERATE',\r\n      target: 'SYSTEM_STATUS',\r\n      payload: { intent: userIntent },\r\n      metadata: {\r\n        requestedBy: userId,\r\n        organizationId: orgId,\r\n        timestamp: new Date().toISOString(),\r\n        intent: userIntent\r\n      }\r\n    };\r\n  }\r\n\r\n  static getValidTargets(): string[] {\r\n    return [\r\n      // === WORKFORCE MANAGEMENT ===\r\n      'EMPLOYEE', \r\n      'TIME_ENTRY', \r\n      'PAYSTUB', \r\n      'PAYROLL_RUN', \r\n      \r\n      // === PROJECT & TASK MANAGEMENT ===\r\n      'PROJECT_TASK', \r\n      'CONTRACT',\r\n      'ORGANIZATION',\r\n      \r\n      // === TRADING & FINANCE ===\r\n      'TRADE',\r\n      'PORTFOLIO',\r\n      'MARKET_DATA',\r\n      \r\n      // === AI & RESEARCH ===\r\n      'AI_RESEARCH',\r\n      'AI_CALCULATOR',\r\n      \r\n      // === BIDDING & PROPOSALS ===\r\n      'BID',\r\n      \r\n      // === COMMUNICATIONS ===\r\n      'EMAIL',\r\n      'DISCORD',\r\n      \r\n      // === SYSTEM & AGENTS ===\r\n      'AGENT',\r\n      'SYSTEM_STATUS'\r\n    ];\r\n  }\r\n}\r\n"
}