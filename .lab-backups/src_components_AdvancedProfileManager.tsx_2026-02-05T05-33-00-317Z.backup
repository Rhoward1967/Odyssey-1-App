{
  "originalPath": "src\\components\\AdvancedProfileManager.tsx",
  "timestamp": "2026-02-05T05:33:00.317Z",
  "hash": "4f555543d66322e5f27ecc4a6771b0f4b16e336370e1fd5a31504059d1bb2c60",
  "size": 7687,
  "content": "import React, { useState, useEffect } from 'react';\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Textarea } from '@/components/ui/textarea';\r\nimport { Avatar, AvatarFallback, AvatarImage } from '@/components/ui/avatar';\r\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';\r\nimport { Badge } from '@/components/ui/badge';\r\nimport { Switch } from '@/components/ui/switch';\r\nimport { User, Settings, Shield, Bell, Camera, Save, Edit3 } from 'lucide-react';\r\nimport { useToast } from '@/hooks/use-toast';\r\nimport { supabase } from '@/lib/supabaseClient';\r\n\r\nexport const AdvancedProfileManager = () => {\r\n  const { toast } = useToast();\r\n  const [isEditing, setIsEditing] = useState(false);\r\n  const [profile, setProfile] = useState({\r\n    firstName: 'John',\r\n    lastName: 'Doe',\r\n    email: 'john.doe@example.com',\r\n    phone: '+1 (555) 123-4567',\r\n    company: 'Acme Corp',\r\n    title: 'Senior Manager',\r\n    bio: 'Experienced professional with expertise in AI and business optimization.',\r\n    location: 'San Francisco, CA',\r\n    timezone: 'PST',\r\n    avatar: '',\r\n    skills: ['AI Strategy', 'Business Analysis', 'Project Management'],\r\n    preferences: {\r\n      emailNotifications: true,\r\n      pushNotifications: false,\r\n      darkMode: false,\r\n      language: 'en'\r\n    }\r\n  });\r\n\r\n  const handleSave = async () => {\r\n    try {\r\n      // Save to Supabase\r\n      const { error } = await supabase\r\n        .from('user_profiles')\r\n        .upsert(profile);\r\n      \r\n      if (error) throw error;\r\n      \r\n      toast({\r\n        title: \"Profile Updated\",\r\n        description: \"Your profile has been successfully updated.\"\r\n      });\r\n      setIsEditing(false);\r\n    } catch (error) {\r\n      toast({\r\n        title: \"Error\",\r\n        description: \"Failed to update profile. Please try again.\",\r\n        variant: \"destructive\"\r\n      });\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"max-w-4xl mx-auto p-6 space-y-6\">\r\n      <div className=\"flex items-center justify-between\">\r\n        <h1 className=\"text-3xl font-bold\">Profile Management</h1>\r\n        <Button \r\n          onClick={() => setIsEditing(!isEditing)}\r\n          variant={isEditing ? \"outline\" : \"default\"}\r\n        >\r\n          {isEditing ? <Save className=\"h-4 w-4 mr-2\" /> : <Edit3 className=\"h-4 w-4 mr-2\" />}\r\n          {isEditing ? 'Save Changes' : 'Edit Profile'}\r\n        </Button>\r\n      </div>\r\n\r\n      <Tabs defaultValue=\"profile\" className=\"space-y-6\">\r\n        <TabsList className=\"grid w-full grid-cols-4\">\r\n          <TabsTrigger value=\"profile\">\r\n            <User className=\"h-4 w-4 mr-2\" />\r\n            Profile\r\n          </TabsTrigger>\r\n          <TabsTrigger value=\"preferences\">\r\n            <Settings className=\"h-4 w-4 mr-2\" />\r\n            Preferences\r\n          </TabsTrigger>\r\n          <TabsTrigger value=\"security\">\r\n            <Shield className=\"h-4 w-4 mr-2\" />\r\n            Security\r\n          </TabsTrigger>\r\n          <TabsTrigger value=\"notifications\">\r\n            <Bell className=\"h-4 w-4 mr-2\" />\r\n            Notifications\r\n          </TabsTrigger>\r\n        </TabsList>\r\n\r\n        <TabsContent value=\"profile\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Personal Information</CardTitle>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <div className=\"flex items-center space-x-4\">\r\n                <Avatar className=\"h-20 w-20\">\r\n                  <AvatarImage src={profile.avatar} />\r\n                  <AvatarFallback>{profile.firstName[0]}{profile.lastName[0]}</AvatarFallback>\r\n                </Avatar>\r\n                {isEditing && (\r\n                  <Button variant=\"outline\" size=\"sm\">\r\n                    <Camera className=\"h-4 w-4 mr-2\" />\r\n                    Change Photo\r\n                  </Button>\r\n                )}\r\n              </div>\r\n\r\n              <div className=\"grid grid-cols-2 gap-4\">\r\n                <div>\r\n                  <Label>First Name</Label>\r\n                  <Input \r\n                    value={profile.firstName}\r\n                    disabled={!isEditing}\r\n                    onChange={(e) => setProfile({...profile, firstName: e.target.value})}\r\n                  />\r\n                </div>\r\n                <div>\r\n                  <Label>Last Name</Label>\r\n                  <Input \r\n                    value={profile.lastName}\r\n                    disabled={!isEditing}\r\n                    onChange={(e) => setProfile({...profile, lastName: e.target.value})}\r\n                  />\r\n                </div>\r\n              </div>\r\n\r\n              <div>\r\n                <Label>Bio</Label>\r\n                <Textarea \r\n                  value={profile.bio}\r\n                  disabled={!isEditing}\r\n                  onChange={(e) => setProfile({...profile, bio: e.target.value})}\r\n                  rows={3}\r\n                />\r\n              </div>\r\n\r\n              <div>\r\n                <Label>Skills</Label>\r\n                <div className=\"flex flex-wrap gap-2 mt-2\">\r\n                  {profile.skills.map((skill, index) => (\r\n                    <Badge key={index} variant=\"secondary\">{skill}</Badge>\r\n                  ))}\r\n                </div>\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"preferences\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>User Preferences</CardTitle>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              <div className=\"flex items-center justify-between\">\r\n                <Label>Dark Mode</Label>\r\n                <Switch \r\n                  checked={profile.preferences.darkMode}\r\n                  disabled={!isEditing}\r\n                />\r\n              </div>\r\n              <div className=\"flex items-center justify-between\">\r\n                <Label>Email Notifications</Label>\r\n                <Switch \r\n                  checked={profile.preferences.emailNotifications}\r\n                  disabled={!isEditing}\r\n                />\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"security\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Security Settings</CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <Button variant=\"outline\">Change Password</Button>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"notifications\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Notification Settings</CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <div className=\"space-y-4\">\r\n                <div className=\"flex items-center justify-between\">\r\n                  <Label>Push Notifications</Label>\r\n                  <Switch \r\n                    checked={profile.preferences.pushNotifications}\r\n                    disabled={!isEditing}\r\n                  />\r\n                </div>\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n      </Tabs>\r\n\r\n      {isEditing && (\r\n        <div className=\"flex justify-end space-x-4\">\r\n          <Button variant=\"outline\" onClick={() => setIsEditing(false)}>\r\n            Cancel\r\n          </Button>\r\n          <Button onClick={handleSave}>\r\n            Save All Changes\r\n          </Button>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n};"
}