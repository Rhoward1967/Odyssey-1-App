  "originalPath": "src\\components\\RealtimeTestimonials.tsx",
  "timestamp": "2026-02-05T05:33:06.198Z",
  "hash": "a56fd303a331800f094cf71e3bc408a1f08bd6edc36049917de23ddef5d561e9",
  "size": 2324,
  "content": "import { Card, CardContent } from '@/components/ui/card';\r\nimport { useRealtimeContent } from '@/hooks/useRealtimeContent';\r\nimport { Star } from 'lucide-react';\r\n\r\nexport const RealtimeTestimonials = () => {\r\n  const { getFeaturedTestimonials, loading } = useRealtimeContent();\r\n  const testimonials = getFeaturedTestimonials();\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"py-20 bg-white\">\r\n        <div className=\"max-w-6xl mx-auto px-4\">\r\n          <div className=\"animate-pulse\">\r\n            <div className=\"h-8 bg-gray-300 rounded w-64 mx-auto mb-12\"></div>\r\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\r\n              {[1, 2, 3].map(i => (\r\n                <div key={i} className=\"h-64 bg-gray-300 rounded-lg\"></div>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (testimonials.length === 0) return null;\r\n\r\n  return (\r\n    <section className=\"py-20 bg-white\">\r\n      <div className=\"max-w-6xl mx-auto px-4\">\r\n        <div className=\"text-center mb-12\">\r\n          <h2 className=\"text-4xl font-bold mb-4\">What Our Clients Say</h2>\r\n          <p className=\"text-xl text-gray-600\">Trusted by businesses nationwide</p>\r\n        </div>\r\n        \r\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\r\n          {testimonials.map((testimonial) => (\r\n            <Card key={testimonial.id} className=\"hover:shadow-lg transition-shadow\">\r\n              <CardContent className=\"p-6\">\r\n                <div className=\"flex mb-4\">\r\n                  {[...Array(testimonial.rating)].map((_, i) => (\r\n                    <Star key={i} className=\"h-5 w-5 text-yellow-400 fill-current\" />\r\n                  ))}\r\n                </div>\r\n                \r\n                <p className=\"text-gray-700 mb-4 italic\">\r\n                  \"{testimonial.testimonial}\"\r\n                </p>\r\n                \r\n                <div className=\"border-t pt-4\">\r\n                  <p className=\"font-semibold\">{testimonial.client_name}</p>\r\n                  {testimonial.company && (\r\n                    <p className=\"text-sm text-gray-500\">{testimonial.company}</p>\r\n                  )}\r\n                </div>\r\n              </CardContent>\r\n            </Card>\r\n          ))}\r\n        </div>\r\n      </div>\r\n    </section>\r\n  );\r\n};"
}